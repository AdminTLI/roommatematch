# Supabase — HTTP API (PostgREST, Auth, Realtime)
# Use the project URL from Supabase Dashboard → Settings → API → Project URL (https://<ref>.supabase.co).
# Required for @supabase/ssr in the browser and in Vercel serverless functions. Never put a postgres:// string here.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database — direct Postgres (Supavisor transaction pooler for serverless)
# Use Dashboard → Database → Connection string → "Transaction pooler" (port 6543, often …pooler.supabase.com:6543).
# Use for: psql, Prisma/Drizzle/pg, CI migrations, scripts (e.g. npm run db:seed). Do not use as supabase-js URL.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# SURFconext SSO (Optional)
SURFCONEXT_CLIENT_ID=your_surfconext_client_id
SURFCONEXT_CLIENT_SECRET=your_surfconext_client_secret
SURFCONEXT_ISSUER=https://connect.test.surfconext.nl/oidc/

# ID Verification (Mock for development)
IDV_PROVIDER=mock
IDV_API_KEY=your_idv_api_key
IDV_API_SECRET=your_idv_api_secret

# Studiekeuzedatabase API
SKDB_API_BASE=https://api.studiekeuzedatabase.nl
SKDB_API_KEY=your_skdb_api_key
SKDB_DUMP_PATH=./data/programs.csv

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Email (app-level: support tickets, etc. - optional)
# Mailjet: get API Key and Secret from Mailjet → Account settings → SMTP and SEND API settings.
# Auth emails (OTP, password reset) are sent by Supabase (configure Mailjet SMTP in Supabase Dashboard).
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key
# Optional: sender used by app emails (defaults: noreply@domumatch.nl, Domu Match)
# SMTP_FROM_EMAIL=noreply@yourdomain.com
# SMTP_FROM_NAME=Your App Name
# Optional: if true, digest emails only send during Amsterdam 09:00-11:00 local time.
# EMAIL_DIGEST_SEND_WINDOW_ENABLED=false

# Analytics
VERCEL_ANALYTICS_ID=your_vercel_analytics_id

# Development
NODE_ENV=development

# Whitelist / demo account + Playwright (see root env.example for full list)
# DEMO_USER_EMAIL=your_whitelist_account@example.com
# DEMO_USER_PASSWORD=your_strong_demo_password_here
# E2E_TEST_PASSWORD=...
# E2E_TEST_EMAIL=...
# E2E_REALTIME_USER_B_EMAIL=...  # optional second account for multi-user tests
