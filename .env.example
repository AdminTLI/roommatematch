# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database
DATABASE_URL=your_database_url

# SURFconext SSO (Optional)
SURFCONEXT_CLIENT_ID=your_surfconext_client_id
SURFCONEXT_CLIENT_SECRET=your_surfconext_client_secret
SURFCONEXT_ISSUER=https://connect.test.surfconext.nl/oidc/

# ID Verification (Mock for development)
IDV_PROVIDER=mock
IDV_API_KEY=your_idv_api_key
IDV_API_SECRET=your_idv_api_secret

# Studiekeuzedatabase API
SKDB_API_BASE=https://api.studiekeuzedatabase.nl
SKDB_API_KEY=your_skdb_api_key
SKDB_DUMP_PATH=./data/programs.csv

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Email (app-level: support tickets, etc. - optional)
# Mailjet: get API Key and Secret from Mailjet → Account settings → SMTP and SEND API settings.
# Auth emails (OTP, password reset) are sent by Supabase (configure Mailjet SMTP in Supabase Dashboard).
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key
# Optional: sender used by app emails (defaults: noreply@domumatch.nl, Domu Match)
# SMTP_FROM_EMAIL=noreply@yourdomain.com
# SMTP_FROM_NAME=Your App Name

# Analytics
VERCEL_ANALYTICS_ID=your_vercel_analytics_id

# Development
NODE_ENV=development
