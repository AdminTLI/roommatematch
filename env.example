# Supabase Configuration
# Get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Direct Postgres (Supavisor transaction pooler, port 6543) — use DATABASE_URL below, not supabase-js.
# Removed SUPABASE_POOLER_URL: it must not be passed as the HTTP base URL to createClient().

# Admin seed token for demo user creation (set to a secure random string)
ADMIN_SEED_TOKEN=your_secure_random_token_here

# Admin shared secret for admin API routes (REQUIRED in production)
# Set to a secure random string (e.g., openssl rand -hex 32)
# Must be included in x-admin-secret header for admin endpoints
ADMIN_SHARED_SECRET=your_secure_random_secret_here

# Whitelisted demo account (preserved during cleanup). Use a strong password; never commit real values.
DEMO_USER_EMAIL=your_whitelist_account@example.com
DEMO_USER_PASSWORD=your_strong_demo_password_here

# Development seed data (set to true only in local development)
ALLOW_DEV_SEED=false
# Password for fake users created by db/seeds/seed.dev.ts (required when ALLOW_DEV_SEED=true)
DEV_SEED_USER_PASSWORD=your_dev_only_seed_password_here

# Playwright E2E (loaded from .env.local / .env.test via playwright.config.ts)
E2E_TEST_PASSWORD=your_e2e_signup_password_here
E2E_TEST_EMAIL=your_existing_test_user@example.com
# Optional: two-account realtime tests (defaults A to E2E_TEST_EMAIL)
# E2E_REALTIME_USER_A_EMAIL=first@example.com
E2E_REALTIME_USER_B_EMAIL=second@example.com

# Database URL: production/Vercel should use Supabase transaction pooler :6543; local dev may use :5432
DATABASE_URL=postgresql://user:password@localhost:5432/domumatch

# SURFconext SSO (optional, feature-flagged)
SURFCONEXT_ENTITY_ID=your_surfconext_entity_id
SURFCONEXT_SSO_URL=https://connect.test.surfconext.nl/saml2/idp/SSOService.php
SURFCONEXT_CERT_PATH=./certs/surfconext.crt

# KYC Verification Provider (veriff/persona/onfido)
KYC_PROVIDER=persona
VERIFF_API_KEY=your_veriff_api_key_here
VERIFF_API_URL=https://station.veriff.com
VERIFF_WEBHOOK_SECRET=your_veriff_webhook_secret_here
PERSONA_API_KEY=your_persona_api_key_here
PERSONA_API_URL=https://withpersona.com/api/v1
PERSONA_WEBHOOK_SECRET=your_persona_webhook_secret_here
# Persona Embedded Flow (for client-side widget — use values from Persona Dashboard)
NEXT_PUBLIC_PERSONA_TEMPLATE_ID=your_persona_template_id
NEXT_PUBLIC_PERSONA_ENVIRONMENT_ID=your_persona_environment_id
ONFIDO_API_KEY=your_onfido_api_key_here
ONFIDO_API_URL=https://api.onfido.com/v3
ONFIDO_WEBHOOK_SECRET=your_onfido_webhook_secret_here

# Feature Flags
FEATURE_HOUSING=false
FEATURE_MOVE_IN=false
ALLOW_DEMO_CHAT=false

# ID Verification Provider (mock for development - deprecated, use KYC_PROVIDER)
IDV_PROVIDER=mock
IDV_API_KEY=your_idv_api_key_here
IDV_WEBHOOK_SECRET=your_webhook_secret_here

# Studiekeuzedatabase API (for programme data enrichment)
# SKDB enriches DUO programme data with additional fields: ECTS credits, duration, admission requirements, etc.
# Primary: API mode (requires API key from https://portal.skdb.nl)
SKDB_API_BASE=https://api.skdb.nl
SKDB_API_KEY=your_skdb_api_key_here

# Alternative: CSV/XLSX dump path (fallback if API not available)
# Download dumps from https://portal.skdb.nl/portaal/ (API v0 downloads section)
SKDB_DUMP_PATH=./data/studiekeuzedatabase_dump.csv

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# Upstash Redis (REQUIRED in production for distributed locking and rate limiting)
# Vercel: add the Upstash integration, or paste credentials from the Upstash console into Vercel → Settings → Environment Variables.
# In Upstash: open your Redis database → tab "REST API" → copy UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN.
# Some Vercel setups use KV_REST_API_URL and KV_REST_API_TOKEN instead; this app accepts either pair.
# Required for multi-instance serverless deployments (e.g., Vercel) to prevent:
# - Concurrent matching operations from the same user
# - Rate limit inconsistencies across instances
# Create a free Redis database at https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here
# Optional alternate names (if your Vercel project already has these from an integration):
# KV_REST_API_URL=https://your-redis-instance.upstash.io
# KV_REST_API_TOKEN=your_token_here

# Email Configuration (app-level emails via Mailjet API)
# Get from Mailjet: Account settings → SMTP and SEND API settings
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key
# Optional: sender (defaults: noreply@domumatch.nl, Domu Match)
# SMTP_FROM_EMAIL=noreply@yourdomain.com
# SMTP_FROM_NAME=Domu Match
# For Supabase auth emails (signup, password reset): configure Mailjet SMTP in Supabase Dashboard (see docs/email-troubleshooting.md)

# Analytics (optional)
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
MIXPANEL_TOKEN=your_mixpanel_token

# Sentry Error Tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
SENTRY_ENABLE_DEV=false

# Cron Configuration
CRON_SECRET=your_secure_cron_secret_here
VERCEL_CRON_SECRET=your_vercel_cron_secret_here

# Vercel Webhook (for automatic update creation)
VERCEL_WEBHOOK_SECRET=your_vercel_webhook_secret_here

# Development
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here